node_modules/
dist/

# Per-package LICENSE is generated by scripts/copy-license.ts at release time.
# Root LICENSE is the source of truth.
packages/*/LICENSE
*.db
test-report.html
.cache/
bun.lockb
.astro/
.local/
.playwright-mcp/

# Ephemeral git worktrees created via Claude's EnterWorktree helper.
# Tracked-out copies of the repo live here; biome/tsc would otherwise
# treat each nested biome.json as a conflicting root config.
.claude/worktrees/

# Per-package local credentials for live integration tests.
# Loaded via `bun --env-file=packages/store-*/.env.local test …`.
.env.local
*.env.local

# The root `.env` typically holds real Turso/GH creds — never commit.
# `.env.example` is the committed template; `.env.test` is the gated
# default for `bun test` and is safe to commit.
.env

# Local log output from FLAKY_TESTS_LOG_FILE.
flaky.log
*.flaky.log
tsconfig.tsbuildinfo
