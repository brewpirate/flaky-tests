# flaky-tests — all environment variables, one file.
#
# Copy to `.env.local` (gitignored) and fill in the values you need. Bun
# auto-loads .env → .env.local → .env.{NODE_ENV} → .env.{NODE_ENV}.local
# in that order; later files win. Only set the variables you actually
# need — every one below has a sensible default or is optional.
#
# NOTE: `.env.test` is also auto-loaded by `bun test` and currently sets
# FLAKY_TESTS_DISABLE=1 to gate the dogfood preload. See README for the
# capture workflow.

# =============================================================================
# Runtime logging
# =============================================================================

# Log level for flaky-tests diagnostics. One of: silent | error | warn | debug.
FLAKY_TESTS_LOG=warn

# Optional append-only file sink. Every active log line goes here IN ADDITION
# to the console sink, timestamped in ISO 8601. Useful when Bun buffers
# stdout or you want to `tail -f` a durable trace.
# FLAKY_TESTS_LOG_FILE=./flaky.log

# =============================================================================
# Plugin / preload
# =============================================================================

# Set to `1` or `true` to turn plugin-bun and plugin-vitest into no-ops.
# Used by this repo's .env.test to avoid capturing self-tests.
# FLAKY_TESTS_DISABLE=1

# Run-id override. Normally set automatically by plugin-bun's run-tracked
# wrapper so a parent process can reconcile exit codes. Don't set manually.
# FLAKY_TESTS_RUN_ID=

# =============================================================================
# Store selection
# =============================================================================

# Which backend to use. Built-in: sqlite | turso | postgres | supabase.
# Any other value is treated as a custom adapter name and looked up through
# the plugin registry (see guides/custom-stores).
FLAKY_TESTS_STORE=sqlite

# Module specifier for the dispatcher to `import()`. Overrides the
# `@flaky-tests/store-<type>` convention — use this for forks or
# third-party adapter packages under a different name.
# FLAKY_TESTS_STORE_MODULE=@acme/store-dynamodb

# -- sqlite ------------------------------------------------------------------

# Path to the SQLite database file (used only when FLAKY_TESTS_STORE=sqlite).
# Default: node_modules/.cache/flaky-tests/failures.db
# FLAKY_TESTS_DB=./.cache/flaky.db

# -- turso / postgres / supabase -------------------------------------------

# Connection string for the chosen remote store.
#   turso:    libsql://<db-name>.turso.io
#   postgres: postgres://user:pass@host:5432/db
#   supabase: https://<project>.supabase.co
# FLAKY_TESTS_CONNECTION_STRING=

# Auth token (Turso) or anon/service-role key (Supabase). Unused for
# local file:: URLs and for Postgres (use connection-string creds).
# FLAKY_TESTS_AUTH_TOKEN=

# =============================================================================
# Detection tuning (CLI)
# =============================================================================

# Recent-window length in days. --window overrides this.
FLAKY_TESTS_WINDOW=7

# Minimum recent failures to flag a test as flaky. --threshold overrides this.
FLAKY_TESTS_THRESHOLD=2

# =============================================================================
# GitHub integration (CLI only, --create-issue flow)
# =============================================================================

# Token used to open issues. Set automatically inside GitHub Actions.
# GITHUB_TOKEN=

# owner/repo for issue creation. Set automatically inside GitHub Actions.
# GITHUB_REPOSITORY=

# =============================================================================
# Report display (CLI only, --html flow)
# =============================================================================

# Override the command used to open the generated HTML report. Standard
# xdg convention — leave unset to use the platform default.
# BROWSER=

# =============================================================================
# Integration-test credentials (CI + local test:integration)
# =============================================================================

# Set to `1` to opt into the integration-tier test suites. These are
# skipped by default so `bun test` stays fast and doesn't need a network.
# INTEGRATION=1

# Contract suite against real remote DBs. Only the store under test needs
# its URL/key set. Safe to leave unset.
# TURSO_TEST_URL=libsql://your-test-db.turso.io
# POSTGRES_TEST_URL=postgres://user:pass@localhost:5432/postgres
# SUPABASE_TEST_URL=https://your-project.supabase.co
# SUPABASE_TEST_KEY=your-supabase-anon-key

# =============================================================================
# Live end-to-end Turso test (local only)
# =============================================================================

# Dedicated skip gate for packages/store-turso/src/live.integration.test.ts.
# Keep separate from INTEGRATION so live tests don't fire on every CI run.
# Run with:
#   bun --env-file=packages/store-turso/.env.local \
#       test packages/store-turso/src/live.integration.test.ts
# FLAKY_TESTS_TURSO_LIVE=1
# TURSO_LIVE_URL=libsql://your-throwaway-db.turso.io
# TURSO_LIVE_TOKEN=eyJhbGciOi...
