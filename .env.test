# Auto-loaded by `bun test`. Default: disable the flaky-tests preload so
# the monorepo's own unit tests (especially plugin-bun's self-tests that
# call `createPreload(mockStore)` directly) don't conflict with a real
# store wiring.
#
# Opt into capture for a run with:
#   FLAKY_TESTS_DISABLE= bun test
#   FLAKY_TESTS_DISABLE= bun run test
#   bun run test:flaky
FLAKY_TESTS_DISABLE=1
