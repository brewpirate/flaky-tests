{
  "name": "@flaky-tests/core",
  "version": "1.0.0",
  "description": "Storage-agnostic core types and CLI for flaky-tests",
  "type": "module",
  "bin": {
    "flaky-tests": "./dist/cli/check.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./test-helpers": {
      "bun": "./src/test-helpers/index.ts",
      "import": "./dist/test-helpers/index.js",
      "types": "./dist/test-helpers/index.d.ts"
    },
    "./cli": {
      "bun": "./src/cli/index.ts",
      "import": "./dist/cli/index.js",
      "types": "./dist/cli/index.d.ts"
    }
  },
  "imports": {
    "#core/*": "./src/*.ts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "src/**/*",
    "!**/*.test.ts",
    "!**/*.test.js",
    "!**/*.test.d.ts",
    "!**/*.test.d.ts.map",
    "!**/*.integration.test.ts",
    "!**/__snapshots__/**",
    "package.json",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts ./src/test-helpers/index.ts ./src/cli/index.ts ./src/cli/check.ts --outdir dist --format esm --target node --external bun:test --external '@flaky-tests/store-sqlite' --external '@flaky-tests/store-turso' --external '@flaky-tests/store-supabase' --external '@flaky-tests/store-postgres' --external '@flaky-tests/core' --external arktype",
    "build:types": "tsc --project tsconfig.build.json",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "license": "MIT",
  "dependencies": {
    "arktype": "^2.2.0"
  },
  "devDependencies": {
    "@flaky-tests/plugin-bun": "workspace:*",
    "@flaky-tests/plugin-vitest": "workspace:*",
    "@flaky-tests/store-postgres": "workspace:*",
    "@flaky-tests/store-sqlite": "workspace:*",
    "@flaky-tests/store-supabase": "workspace:*",
    "@flaky-tests/store-turso": "workspace:*",
    "bun-types": "^1.3.13"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.0"
  },
  "author": "Daniel Zenner <daniel@zenner.dev>",
  "homepage": "https://brewpirate.github.io/flaky-tests",
  "bugs": {
    "url": "https://github.com/brewpirate/flaky-tests/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brewpirate/flaky-tests.git",
    "directory": "packages/core"
  },
  "keywords": [
    "flaky-tests",
    "test-flakiness",
    "bun",
    "vitest",
    "cli",
    "ai",
    "claude",
    "cursor"
  ]
}
