{
  "name": "@flaky-tests/core",
  "version": "0.1.0",
  "description": "Storage-agnostic core types and utilities for flaky-tests",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist/", "src/", "package.json", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --format esm --target node",
    "build:types": "tsc --project tsconfig.build.json",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "license": "MIT",
  "dependencies": {
    "arktype": "^2.2.0"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
