# Copy this file to `.env.local` in the same directory (it is gitignored).
#
# Run the live-turso integration test with:
#
#   bun --env-file=packages/store-turso/.env.local test packages/store-turso/src/live.integration.test.ts
#
# `FLAKY_TESTS_TURSO_LIVE=1` is the skip gate. Omit it to keep the test
# skipped even if a .env.local exists (handy for CI and shared machines).

FLAKY_TESTS_TURSO_LIVE=1
TURSO_LIVE_URL=libsql://your-db-name.turso.io
TURSO_LIVE_TOKEN=eyJhbGciOi...
