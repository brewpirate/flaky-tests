{
  "name": "@flaky-tests/plugin-vitest",
  "version": "0.1.0",
  "description": "Vitest reporter plugin for flaky-tests",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist/", "src/", "package.json", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --format esm --target node --external @flaky-tests/core --external vitest",
    "build:types": "tsc --project tsconfig.build.json",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "license": "MIT",
  "dependencies": {
    "@flaky-tests/core": "workspace:*"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "bun-types": "latest"
  }
}
