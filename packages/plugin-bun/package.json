{
  "name": "@flaky-tests/plugin-bun",
  "version": "0.1.0",
  "description": "Bun test preload plugin for flaky-tests",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./preload": {
      "bun": "./src/preload-default.ts",
      "import": "./dist/preload-default.js",
      "types": "./dist/preload-default.d.ts"
    },
    "./run-tracked": {
      "bun": "./src/run-tracked.ts",
      "import": "./dist/run-tracked.js",
      "types": "./dist/run-tracked.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist/", "src/", "package.json", "LICENSE"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "bun build ./src/index.ts ./src/preload-default.ts ./src/run-tracked.ts --outdir dist --format esm --target node --external @flaky-tests/core --external @flaky-tests/store-sqlite --external @flaky-tests/store-turso --external @flaky-tests/store-supabase --external @flaky-tests/store-postgres --external bun:sqlite --external bun:test",
    "build:types": "tsc --project tsconfig.build.json",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "license": "MIT",
  "dependencies": {
    "@flaky-tests/core": "workspace:*"
  },
  "optionalDependencies": {
    "@flaky-tests/store-sqlite": "workspace:*",
    "@flaky-tests/store-turso": "workspace:*",
    "@flaky-tests/store-supabase": "workspace:*",
    "@flaky-tests/store-postgres": "workspace:*"
  },
  "devDependencies": {
    "@flaky-tests/store-sqlite": "workspace:*",
    "bun-types": "latest"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
