{
  "name": "flaky-tests",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "format": "bun x --bun @biomejs/biome format",
    "format:fix": "bun x @biomejs/biome format --write",
    "lint": "bun x @biomejs/biome lint",
    "lint:fix": "bun x @biomejs/biome lint --fix",
    "test": "bun test",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@biomejs/biome": "2.4.12"
  }
}