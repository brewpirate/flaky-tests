{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "assist": {
    "actions": {
      "source": {
        "noDuplicateClasses": "on",
        "organizeImports": "on"
      }
    },
    "enabled": true
  },
  "files": {
    "includes": [
      "**",
      "!!**/dist",
      "!!**/tests",
      "!!scripts",
      "!!**/node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    }
  },
  "json": {
    "formatter": {
      "enabled": false
    },
    "linter": {
      "enabled": false
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "complexity": {
        "noUselessTernary": "error",
        "noUselessTypeConstraint": "error"
      },
      "recommended": true,
      "suspicious": {
        "noConsole": "error"
      },
      "style": {
        "noNestedTernary": "error",
        "useNodejsImportProtocol": "off",
        "noProcessEnv": "error",
        "noMagicNumbers": "error",
        "noParameterAssign": "error",
        "useArrayLiterals": "error"
      },
      "nursery": {
        "useSortedClasses": "info"
      }
    }
  },
  "vcs": {
    "clientKind": "git",
    "defaultBranch": "main",
    "enabled": true,
    "useIgnoreFile": true
  }
}