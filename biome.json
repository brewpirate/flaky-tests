{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "assist": {
    "actions": {
      "source": {
        "noDuplicateClasses": "on",
        "organizeImports": "on"
      }
    },
    "enabled": true
  },
  "files": {
    "includes": [
      "**",
      "!!**/dist",
      "!!**/tests",
      "!!scripts",
      "!!**/node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    }
  },
  "json": {
    "formatter": {
      "enabled": false
    },
    "linter": {
      "enabled": false
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "complexity": {
        "noUselessTernary": "error",
        "noUselessTypeConstraint": "error",
        "noForEach": "error",
        "noUselessCatch": "error",
        "noUselessStringConcat": "error",
        "useDateNow": "error"
      },
      "correctness": {
        "noUnusedImports": "error"
      },
      "recommended": true,
      "suspicious": {
        "noConsole": "error",
        "noExplicitAny": "error",
        "noTsIgnore": "error",
        "noEmptyBlockStatements": "error",
        "useAwait": "error",
        "noImplicitAnyLet": "error",
        "noEvolvingTypes": "error",
        "noConfusingVoidType": "error"
      },
      "style": {
        "noNestedTernary": "error",
        "useNodejsImportProtocol": "off",
        "noProcessEnv": "error",
        "noMagicNumbers": "error",
        "noParameterAssign": "error",
        "useArrayLiterals": "error",
        "noNonNullAssertion": "error",
        "useImportType": "error",
        "useExportType": "error",
        "useThrowOnlyError": "error",
        "useBlockStatements": "error",
        "useTemplate": "error",
        "useConsistentArrayType": {
          "level": "error",
          "options": {
            "syntax": "shorthand"
          }
        },
        "noDoneCallback": "error",
        "noYodaExpression": "error"
      },
      "nursery": {
        "useSortedClasses": "info",
        "noFloatingPromises": "error",
        "useExhaustiveSwitchCases": "error",
        "useNullishCoalescing": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/*.test.ts",
        "**/*.integration.test.ts",
        "packages/core/src/test-helpers/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noMagicNumbers": "off"
          },
          "suspicious": {
            "noEmptyBlockStatements": "off",
            "noConsole": "off",
            "useAwait": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/core/src/config.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noProcessEnv": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/store-sqlite/src/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "useAwait": "off"
          }
        }
      }
    }
  ],
  "vcs": {
    "clientKind": "git",
    "defaultBranch": "main",
    "enabled": true,
    "useIgnoreFile": true
  }
}